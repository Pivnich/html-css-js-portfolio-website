---
import FramerInView from '../FramerInView.tsx'
import OptimizedImage from '../OptimizedImage.astro'
import telegramIcon from '../../assets/social/telegram.png'
import linkedinIcon from '../../assets/social/linkedin.png'
import behanceIcon from '../../assets/social/behance-logo-0DC7CB7635-seeklogo.com.png'
---

<section id="profile">
	<!-- <FramerInView client:load class="section__pic-container">
		<img
			src="assets/profile-pic.jpg"
			alt="Maksym Vulchyn profile picture"
			width="100%"
			height="100%"
		loading="lazy" decoding="async" />
	</FramerInView> -->
	<FramerInView client:load className="section__text">
		<p class="section__text__p1">Hello, I am Max!</p>
		<p class="section__text__p2">Graphic Designer, Video Editor, 3d Artist</p>

		<a class="btn btn-accent" href="#contact"> Contact Info </a>
		<div class="socials-container">
			<a href="https://t.me/gonzoshrimp" target="_blank" title="Telegram">
				<OptimizedImage
					src={telegramIcon}
					alt="Telegram"
					class="icon"
					width={32}
					height={32}
					loading="eager"
				/>
			</a>
			<a href="https://linkedin.com/in/maksymvulchyn" target="_blank" title="LinkedIn">
				<OptimizedImage
					src={linkedinIcon}
					alt="Linkedin"
					class="icon"
					width={32}
					height={32}
					loading="eager"
				/>
			</a>
			<a href="https://www.behance.net/maxvulchyn" target="_blank" title="Behance">
				<OptimizedImage
					src={behanceIcon}
					alt="Behance"
					class="icon"
					width={32}
					height={32}
					loading="eager"
				/>
			</a>
		</div>
	</FramerInView>
</section>
